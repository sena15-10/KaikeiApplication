<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="2dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp">

        <!-- 商品名 -->
        <TextView
            android:id="@+id/listPrductName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="商品名"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toStartOf="@id/editBtn" />


            <!-- 単価 -->
        <TextView
            android:id="@+id/listProductPrice"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="¥0 / 個"
            android:textSize="13sp"
            android:textColor="@color/text_secondary"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/listPrductName"
            app:layout_constraintEnd_toStartOf="@id/editBtn" />

        <!-- ー ボタン -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/editBtn"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:text="-"
            android:textSize="18sp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:cornerRadius="4dp"
            app:layout_constraintEnd_toStartOf="@id/listQuantityS"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <!-- 数量 -->
        <TextView
            android:id="@+id/listQuantityS"
            android:layout_width="36dp"
            android:layout_height="wrap_content"
            android:text="0"
            android:textSize="16sp"
            android:gravity="center"
            app:layout_constraintEnd_toStartOf="@id/deleteBtn"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <!-- ＋ ボタン -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/deleteBtn"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:text="+"
            android:textSize="18sp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:cornerRadius="4dp"
            app:layout_constraintEnd_toStartOf="@id/listSubtotal"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <!-- 小計金額 -->
        <TextView
            android:id="@+id/listSubtotal"
            android:layout_width="72dp"
            android:layout_height="wrap_content"
            android:text="¥0"
            android:textSize="15sp"
            android:gravity="end"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.cardview.widget.CardView>
