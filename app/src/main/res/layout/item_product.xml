<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="2dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp">

        <!-- 1. 商品名: 在庫ラベルの左側で止まるように設定 -->
        <TextView
            android:id="@+id/listProductName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="非常に長い商品名のテストサンプルテキスト"
            android:textSize="16sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toStartOf="@id/labelStock"
            android:layout_marginEnd="8dp" />

        <!-- 2. 在庫ラベル: 位置を固定（マイナスボタンの左側に配置） -->
        <TextView
            android:id="@+id/labelStock"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/tvStockItem"
            android:textSize="12sp"
            app:layout_constraintEnd_toStartOf="@id/btnMinus"
            app:layout_constraintTop_toTopOf="parent"
            android:layout_marginEnd="8dp" />

        <!-- 3. 単価: 商品名と同様に在庫情報の左で止まるように -->
        <TextView
            android:id="@+id/listProductPrice"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="¥0 / 個"
            android:textSize="13sp"
            android:textColor="@color/text_secondary"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/listProductName"
            app:layout_constraintEnd_toStartOf="@id/labelStock"
            android:layout_marginEnd="8dp" />

        <!-- 4. 在庫数: labelStock の真下に配置 -->
        <TextView
            android:id="@+id/tvStockCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="50"
            android:textSize="24sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="@id/labelStock"
            app:layout_constraintEnd_toEndOf="@id/labelStock"
            app:layout_constraintTop_toBottomOf="@id/labelStock" />

        <!--5. 操作ボタン類 -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnMinus"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:text="-"
            android:padding="0dp"
            android:insetLeft="0dp"
            android:insetTop="0dp"
            android:insetRight="0dp"
            android:insetBottom="0dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            app:layout_constraintEnd_toStartOf="@id/tvQuantity"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            android:layout_marginEnd="4dp" />

        <TextView
            android:id="@+id/tvQuantity"
            android:layout_width="32dp"
            android:layout_height="wrap_content"
            android:text="0"
            android:gravity="center"
            app:layout_constraintEnd_toStartOf="@+id/btnPlus"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPlus"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:text="+"
            android:padding="0dp"
            android:insetLeft="0dp"
            android:insetTop="0dp"
            android:insetRight="0dp"
            android:insetBottom="0dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            app:layout_constraintEnd_toStartOf="@id/listSubtotal"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            android:layout_marginEnd="8dp" />

        <TextView
            android:id="@+id/listSubtotal"
            android:layout_width="60dp"
            android:layout_height="wrap_content"
            android:text="¥0"
            android:gravity="end"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.cardview.widget.CardView>